rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function validReportCondition(condition) {
      return condition in [
        'SUNNY',
        'PARTLY_CLOUDY',
        'CLOUDY',
        'RAIN',
        'HEAVY_RAIN',
        'SNOW',
        'FOG',
        'WIND',
        'HAIL',
        'TORNADO'
      ];
    }

    function validAnonymousDeviceId(deviceId) {
      return deviceId is string
        && deviceId.size() == 64
        && deviceId.matches('^[a-f0-9]{64}$');
    }

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Community weather reports
    match /community_reports/{reportId} {
      // Anyone can read reports (needed for map display)
      allow read: if true;

      // Create: validate required fields and enforce limits.
      // hasOnly() rejects payloads with unexpected extra keys; timestamp must be
      // epoch millis near the server clock (+2 min future skew, -10 min past).
      allow create: if request.resource.data.keys().hasAll(['latitude', 'longitude', 'condition', 'deviceId', 'timestamp'])
        && request.resource.data.keys().hasOnly(['latitude', 'longitude', 'condition', 'deviceId', 'timestamp', 'note'])
        && request.resource.data.latitude is number
        && request.resource.data.latitude >= -90
        && request.resource.data.latitude <= 90
        && request.resource.data.longitude is number
        && request.resource.data.longitude >= -180
        && request.resource.data.longitude <= 180
        && request.resource.data.condition is string
        && validReportCondition(request.resource.data.condition)
        && request.resource.data.timestamp is int
        && request.resource.data.timestamp <= request.time.toMillis() + 120000
        && request.resource.data.timestamp >= request.time.toMillis() - 600000
        && (!request.resource.data.keys().hasAny(['note'])
          || (request.resource.data.note is string && request.resource.data.note.size() <= 100))
        && validAnonymousDeviceId(request.resource.data.deviceId);

      // Anonymous append-only model: reports are not editable or deletable.
      allow delete: if false;

      // No updates allowed.
      allow update: if false;
    }
  }
}
