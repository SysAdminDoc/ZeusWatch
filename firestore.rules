rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function validReportCondition(condition) {
      return condition in [
        'SUNNY',
        'PARTLY_CLOUDY',
        'CLOUDY',
        'RAIN',
        'HEAVY_RAIN',
        'SNOW',
        'FOG',
        'WIND',
        'HAIL',
        'TORNADO'
      ];
    }

    function validGeohash(geohash) {
      return geohash is string
        && geohash.size() >= 3
        && geohash.size() <= 12
        && geohash.matches('^[0-9bcdefghjkmnpqrstuvwxyz]+$');
    }

    function validCoarsenedCoordinate(value) {
      let scaled = value * 100;
      let rounded = math.round(scaled);
      // Small tolerance accounts for IEEE-754 representation of decimals.
      return scaled >= rounded - 0.000001
        && scaled <= rounded + 0.000001;
    }

    // Minimum gap between two reports from the same anonymous account, enforced
    // server-side via the report_throttles/{uid} doc updated in the same commit.
    function rateLimitOk(uid) {
      let throttle = /databases/$(database)/documents/report_throttles/$(uid);
      // The create batch must bump this account's throttle doc to the commit time.
      return getAfter(throttle).data.lastReportAt == request.time
        && (
          !exists(throttle)
          || request.time > get(throttle).data.lastReportAt + duration.value(5, 'm')
        );
    }

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Per-account write-rate-limit ledger. One doc per anonymous uid holding the
    // server timestamp of that account's most recent report. Only the owning
    // account may read/write its own ledger, and the only writable value is the
    // commit time itself (so it cannot be backdated to defeat the rate limit).
    match /report_throttles/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['lastReportAt'])
        && request.resource.data.lastReportAt == request.time;
      allow delete: if false;
    }

    // Community weather reports.
    match /community_reports/{reportId} {
      // Single-document reads require an (anonymous) account so the collection is
      // not a fully open firehose. The standard flavor signs in anonymously
      // before any read.
      allow get: if request.auth != null;

      // Collection queries must be bounded: cap the page size so no client can
      // pull the whole collection in one read. The app queries geohash-prefix +
      // timestamp windows with limit(50); rules cannot inspect where-clauses, so
      // the enforceable server-side bound is the query limit.
      allow list: if request.auth != null
        && request.query.limit <= 50;

      // Create: requires an authenticated (anonymous) account, validates every
      // field, enforces a timestamp near the server clock (+2 min future skew,
      // -10 min past), requires a timestamp TTL approximately two hours after
      // creation, and enforces a per-account write-rate limit via
      // report_throttles. Reports are stored WITHOUT an owner id so readers
      // cannot correlate one account's reports into a movement history; the
      // rate-limit binding lives entirely in the per-uid throttle ledger.
      // hasOnly() rejects payloads with unexpected extra keys.
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['latitude', 'longitude', 'geohash', 'condition', 'timestamp', 'expiresAt'])
        && request.resource.data.keys().hasOnly(['latitude', 'longitude', 'geohash', 'condition', 'timestamp', 'expiresAt', 'note'])
        && request.resource.data.latitude is number
        && request.resource.data.latitude >= -90
        && request.resource.data.latitude <= 90
        && validCoarsenedCoordinate(request.resource.data.latitude)
        && request.resource.data.longitude is number
        && request.resource.data.longitude >= -180
        && request.resource.data.longitude <= 180
        && validCoarsenedCoordinate(request.resource.data.longitude)
        && validGeohash(request.resource.data.geohash)
        && request.resource.data.condition is string
        && validReportCondition(request.resource.data.condition)
        && request.resource.data.timestamp is int
        && request.resource.data.timestamp <= request.time.toMillis() + 120000
        && request.resource.data.timestamp >= request.time.toMillis() - 600000
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt.toMillis() >= request.resource.data.timestamp + 7140000
        && request.resource.data.expiresAt.toMillis() <= request.resource.data.timestamp + 7260000
        && (!request.resource.data.keys().hasAny(['note'])
          || (request.resource.data.note is string && request.resource.data.note.size() <= 100))
        && rateLimitOk(request.auth.uid);

      // Anonymous append-only model: reports are not editable or deletable.
      allow delete: if false;

      // No updates allowed.
      allow update: if false;
    }
  }
}
