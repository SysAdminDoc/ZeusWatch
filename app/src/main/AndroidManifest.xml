<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Allow aicore (Gemini Nano) library which requires minSdk 31 — runtime checks guard usage -->
    <uses-sdk tools:overrideLibrary="com.google.ai.edge.aicore" />

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Location — foreground only. The app fetches location while in use and
         persists the last fix; widgets/workers read that cached fix, so no
         ACCESS_BACKGROUND_LOCATION is required (and declaring it unused trips
         Google Play's background-location policy review). -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Widgets -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <queries>
        <intent>
            <action android:name="com.sysadmindoc.nimbus.ICON_PACK" />
        </intent>
        <intent>
            <action android:name="nodomain.freeyourgadget.gadgetbridge.ACTION_GENERIC_WEATHER" />
        </intent>
    </queries>

    <application
        android:name=".NimbusApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ZeusWatch"
        android:enableOnBackInvokedCallback="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <profileable android:shell="true" />

        <!-- singleTask: notification deep links re-route through onNewIntent
             instead of stacking/recreating the activity, so PendingIntents
             don't need CLEAR_TASK (which nuked in-progress task state). -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.ZeusWatch">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep links for app shortcuts -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="zeuswatch" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- FileProvider for sharing weather images -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Widget Configuration Activity -->
        <activity
            android:name=".widget.WidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.ZeusWatch">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- Disable default WorkManager initializer (custom Configuration.Provider) -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Small Widget (2x1): temp + icon -->
        <receiver
            android:name=".widget.NimbusSmallWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_small_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_small_info" />
        </receiver>

        <!-- Medium Widget (3x2): current + 3-day -->
        <receiver
            android:name=".widget.NimbusMediumWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_medium_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_medium_info" />
        </receiver>

        <!-- Large Widget (4x3): hourly + 5-day -->
        <receiver
            android:name=".widget.NimbusLargeWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_large_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_large_info" />
        </receiver>

        <!-- Forecast Strip Widget (4x1): hourly temps -->
        <receiver
            android:name=".widget.NimbusForecastStripWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_forecast_strip_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_forecast_strip_info" />
        </receiver>

        <!-- Saved Cities Widget (4x3): multiple saved locations -->
        <receiver
            android:name=".widget.NimbusSavedCitiesWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_saved_cities_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_saved_cities_info" />
        </receiver>

        <!-- Temperature Widget (1x1): temp + icon only -->
        <receiver
            android:name=".widget.NimbusTempWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_temp_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_temp_info" />
        </receiver>

        <!-- Compact Widget (2x1): temp + icon + hi/lo -->
        <receiver
            android:name=".widget.NimbusCompactWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_compact_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_compact_info" />
        </receiver>

        <!-- Daily Forecast Widget (4x2): 7-day outlook -->
        <receiver
            android:name=".widget.NimbusDailyWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_daily_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_daily_info" />
        </receiver>

        <!-- Live Weather Wallpaper -->
        <service
            android:name=".wallpaper.WeatherWallpaperService"
            android:label="@string/wallpaper_label"
            android:permission="android.permission.BIND_WALLPAPER"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>
            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/weather_wallpaper" />
        </service>

        <!-- Quick Settings Tile -->
        <service
            android:name=".tile.WeatherQuickSettingsTile"
            android:label="@string/qs_tile_label"
            android:icon="@drawable/ic_w_sunny"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>

    <!-- Remove default WorkManager initializer (using custom Configuration.Provider) -->

</manifest>
