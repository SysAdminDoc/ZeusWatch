<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
        <!-- No <certificateTransparency> here: it is not an AOSP
             network-security-config element and no CT library is bundled, so it
             was silently ignored (false MITM assurance). Cert pinning
             (ApiCertificatePins) provides the actual MITM protection. -->
    </base-config>
</network-security-config>
