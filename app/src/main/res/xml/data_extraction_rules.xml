<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- nimbus_prefs holds API keys + last location; nimbus.db holds the
         user's saved/home coordinates. Exclude both from cloud backup AND
         device-to-device transfer (the latter is independent of allowBackup,
         so the DB must be listed here explicitly or it rides along on a clone). -->
    <cloud-backup>
        <exclude domain="sharedpref" path="nimbus_prefs.preferences_pb" />
        <exclude domain="database" path="nimbus.db" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="nimbus_prefs.preferences_pb" />
        <exclude domain="database" path="nimbus.db" />
    </device-transfer>
</data-extraction-rules>
